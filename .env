
# ======================================================
# Django Security Settings
# ======================================================

# Django Secret Key
# Production me strong random secret key use karein
SECRET_KEY=django-insecure-change-this-to-a-real-secret-key

# Debug Mode
# Development=True
# Production=False
DEBUG=False

# Website jis IP ya Domain se access hogi usse comma se alag karke likhein.
#
# Examples:
# ALLOWED_HOSTS=192.168.1.10
# ALLOWED_HOSTS=103.xxx.xxx.xxx
# ALLOWED_HOSTS=reports.example.com
# ALLOWED_HOSTS=reports.example.com,103.xxx.xxx.xxx,127.0.0.1,localhost
#
ALLOWED_HOSTS=127.0.0.1,localhost,192.168.7.4

# Server Time Zone
TIME_ZONE=Asia/Kolkata


# ======================================================
# HTTPS / Security Headers
# ======================================================

# HTTP ko HTTPS par redirect kare.
# Reverse Proxy (Nginx + SSL) use karne par True karein.
SECURE_SSL_REDIRECT=False

# Session Cookie sirf HTTPS par bheji jayegi.
SESSION_COOKIE_SECURE=False

# CSRF Cookie sirf HTTPS par bheji jayegi.
CSRF_COOKIE_SECURE=False

# HTTP Strict Transport Security (HSTS)
# HTTPS use nahi kar rahe ho to 0 rakhein.
SECURE_HSTS_SECONDS=0

# HTTPS use karne par True karein.
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Browser Security Headers
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True

# Clickjacking Protection
X_FRAME_OPTIONS=DENY


# ======================================================
# PostgreSQL Database Settings
# ======================================================

# Database Name
DB_NAME=employee_reports_db

# Database Username
DB_USER=db_user

# Database Password
DB_PASSWORD=strong_db_password

# Docker Compose me database service ka naam
DB_HOST=db

# PostgreSQL Port
DB_PORT=5432

# Database Connection Pool Lifetime (Seconds)
DB_CONN_MAX_AGE=60


# ======================================================
# Email Configuration
# ======================================================

# Development:
# django.core.mail.backends.console.EmailBackend
#
# Production:
# django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

DEFAULT_FROM_EMAIL=noreply@company.com


# ======================================================
# Django Superuser
# ======================================================

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=Admin@dird123

